PORT=3100
# Comma-separated list of trusted device tokens for initial local-device authentication.
# Example: DEVICE_TOKENS=desktop-dev-token,web-dev-token
DEVICE_TOKENS=desktop-dev-token

# M2 persistence files (relative to apps/companion-backend by default)
DATA_PATH_CHATS=./.data/chats.json
DATA_PATH_MEMORY=./.data/memory.json

# Deterministic rollover threshold for starting a fresh session context.
SESSION_MAX_MESSAGES=20
